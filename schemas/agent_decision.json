{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "AgentDecision",
  "required": ["agent", "actions", "sentiment"],
  "properties": {
    "agent": {
      "type": "string",
      "enum": ["whale", "retail", "permabull"]
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["asset", "action", "amount_pct", "reason"],
        "properties": {
          "asset": {
            "type": "string",
            "enum": ["cash", "fd", "gov_bonds", "nifty_50", "nifty_it", "real_estate", "crypto", "gold"]
          },
          "action": {
            "type": "string",
            "enum": ["buy", "sell", "hold"]
          },
          "amount_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200
          }
        }
      }
    },
    "sentiment": {
      "type": "string",
      "enum": ["bullish", "bearish", "neutral", "panic", "cautious"]
    }
  }
}
